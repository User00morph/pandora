// PANDORA OS / STIS — Monday Gold Box Indicator
// Nathan Banks' IEC (Institutional Expansion Cycle) methodology
//
// Monday = Phase 1-2 (Accumulation + Manipulation range)
// True directional expansion develops Tuesday–Thursday (Phase 3)
// This indicator marks Monday's range and tracks weekly price action relative to it.

//@version=5
indicator("Monday Gold Box [IEC]", overlay=true, max_boxes_count=52, max_lines_count=200, max_labels_count=200)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────

grp_box   = "Box Settings"
grp_lines = "Lines & Labels"
grp_bg    = "Background"
grp_colors = "Colors"

show_box    = input.bool(true,  "Show Monday Gold Box",      group=grp_box)
box_opacity = input.int(85,     "Box Opacity (0=solid, 100=invisible)", minval=0, maxval=100, group=grp_box)
extend_box  = input.bool(true,  "Extend Box to End of Week", group=grp_box)

show_midline  = input.bool(true, "Show 50% Equilibrium Line",                      group=grp_lines)
show_labels   = input.bool(true, "Show Labels",                                    group=grp_lines)
show_bull_ext = input.bool(true, "Show Bullish Extension Line (above Mon High)",   group=grp_lines)
show_bear_ext = input.bool(true, "Show Bearish Extension Line (below Mon Low)",    group=grp_lines)

show_bg    = input.bool(true, "Show Background Color", group=grp_bg)
bg_opacity = input.int(90,    "Background Opacity",    minval=0, maxval=100, group=grp_bg)

col_box_fill   = input.color(color.new(color.orange, 85), "Box Fill Color",     group=grp_colors)
col_box_border = input.color(color.new(color.yellow, 20), "Box Border Color",   group=grp_colors)
col_midline    = input.color(color.new(color.white,  40), "Midline Color",      group=grp_colors)
col_bull       = input.color(color.new(color.lime,   10), "Bullish Line Color", group=grp_colors)
col_bear       = input.color(color.new(color.red,    10), "Bearish Line Color", group=grp_colors)
col_bg_bull    = input.color(color.new(color.green,  92), "BG Bull Color",      group=grp_colors)
col_bg_bear    = input.color(color.new(color.red,    92), "BG Bear Color",      group=grp_colors)

// ─────────────────────────────────────────────────────────────────────────────
// MONDAY DETECTION & HIGH/LOW TRACKING
// ─────────────────────────────────────────────────────────────────────────────

is_monday = dayofweek == dayofweek.monday

// Fires once per week on the first bar of Monday (works on H1/H4/D)
is_monday_open = is_monday and not is_monday[1]

var float mon_high    = na
var float mon_low     = na
var float mon_mid     = na
var int   mon_open_bar = na

if is_monday_open
    mon_high      := high
    mon_low       := low
    mon_open_bar  := bar_index

// Update across all Monday candles (intraday charts have multiple Monday bars)
if is_monday
    mon_high := math.max(mon_high, high)
    mon_low  := math.min(mon_low,  low)

if not na(mon_high) and not na(mon_low)
    mon_mid := (mon_high + mon_low) / 2

// ─────────────────────────────────────────────────────────────────────────────
// BOX, LINES & LABELS
// ─────────────────────────────────────────────────────────────────────────────

var box   gold_box  = na
var line  mid_line  = na
var line  bull_line = na
var line  bear_line = na
var label lbl_high  = na
var label lbl_low   = na
var label lbl_mid   = na

if is_monday_open and not na(mon_high) and barstate.isconfirmed
    box.delete(gold_box)
    line.delete(mid_line)
    line.delete(bull_line)
    line.delete(bear_line)
    label.delete(lbl_high)
    label.delete(lbl_low)
    label.delete(lbl_mid)

    right_bar = bar_index + 500

    if show_box
        gold_box := box.new(
             left=bar_index, top=mon_high, right=right_bar, bottom=mon_low,
             border_color=col_box_border, border_width=1,
             bgcolor=col_box_fill, extend=extend.none)

    if show_midline
        mid_line := line.new(
             x1=bar_index, y1=mon_mid, x2=right_bar, y2=mon_mid,
             color=col_midline, style=line.style_dashed, width=1)

    if show_bull_ext
        bull_line := line.new(
             x1=bar_index, y1=mon_high, x2=right_bar, y2=mon_high,
             color=col_bull, style=line.style_dotted, width=2)

    if show_bear_ext
        bear_line := line.new(
             x1=bar_index, y1=mon_low, x2=right_bar, y2=mon_low,
             color=col_bear, style=line.style_dotted, width=2)

    if show_labels
        lbl_high := label.new(x=right_bar, y=mon_high, text="MON HIGH",
             color=color.new(color.orange, 60), textcolor=color.white,
             style=label.style_label_left, size=size.small)
        lbl_low := label.new(x=right_bar, y=mon_low, text="MON LOW",
             color=color.new(color.orange, 60), textcolor=color.white,
             style=label.style_label_left, size=size.small)
        lbl_mid := label.new(x=right_bar, y=mon_mid, text="50% EQ",
             color=color.new(color.gray, 60), textcolor=color.white,
             style=label.style_label_left, size=size.tiny)

// Extend all objects rightward every bar after Monday
is_friday  = dayofweek == dayofweek.friday
right_edge = is_friday and not extend_box ? bar_index : bar_index + 4

if not na(gold_box) and not is_monday_open
    box.set_right(gold_box,  right_edge)
    box.set_top(gold_box,    mon_high)
    box.set_bottom(gold_box, mon_low)

if not na(mid_line) and not is_monday_open
    line.set_x2(mid_line, right_edge)
    line.set_y1(mid_line, mon_mid)
    line.set_y2(mid_line, mon_mid)

if not na(bull_line) and not is_monday_open
    line.set_x2(bull_line, right_edge)
    line.set_y1(bull_line, mon_high)
    line.set_y2(bull_line, mon_high)

if not na(bear_line) and not is_monday_open
    line.set_x2(bear_line, right_edge)
    line.set_y1(bear_line, mon_low)
    line.set_y2(bear_line, mon_low)

if not na(lbl_high) and not is_monday_open
    label.set_x(lbl_high, right_edge)
    label.set_y(lbl_high, mon_high)

if not na(lbl_low) and not is_monday_open
    label.set_x(lbl_low, right_edge)
    label.set_y(lbl_low, mon_low)

if not na(lbl_mid) and not is_monday_open
    label.set_x(lbl_mid, right_edge)
    label.set_y(lbl_mid, mon_mid)

// ─────────────────────────────────────────────────────────────────────────────
// BACKGROUND BIAS SIGNAL
// Green  = above Monday high  → Phase 3 bullish expansion confirmed
// Red    = below Monday low   → Phase 3 bearish expansion confirmed
// Neutral = inside Mon range  → Phase 1-2 (wait)
// ─────────────────────────────────────────────────────────────────────────────

above_box = not na(mon_high) and close > mon_high
below_box = not na(mon_low)  and close < mon_low

bg_color = show_bg ?
     above_box ? col_bg_bull :
     below_box ? col_bg_bear :
     na : na

bgcolor(bg_color)

// ─────────────────────────────────────────────────────────────────────────────
// REFERENCE PLOTS (anchor for alert conditions)
// ─────────────────────────────────────────────────────────────────────────────

plot(not na(mon_high) ? mon_high : na, "Monday High", color=color.new(color.orange, 60), linewidth=1, style=plot.style_circles)
plot(not na(mon_low)  ? mon_low  : na, "Monday Low",  color=color.new(color.orange, 60), linewidth=1, style=plot.style_circles)
plot(not na(mon_mid)  ? mon_mid  : na, "Monday Mid",  color=color.new(color.gray,   70), linewidth=1, style=plot.style_circles)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────

alertcondition(above_box and not above_box[1], "Bullish IEC Breakout",  "Price broke above Monday High — Bullish IEC Phase 3 expansion")
alertcondition(below_box and not below_box[1], "Bearish IEC Breakdown", "Price broke below Monday Low  — Bearish IEC Phase 3 expansion")
