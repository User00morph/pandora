// STIS — Vanna / VIX Bias Indicator
// Layer 1b | Vanna Direction from VIX Trend
// Companion to: gex_levels_v1.pine, skill_gex-regime-read.md (Question 2)
// Reads VIX directly. Run on ANY instrument — Vanna is a global force.
// Pine Script v6

//@version=6
indicator("STIS — Vanna / VIX Bias", overlay=false)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
vix_sma_len    = input.int(5,  "VIX SMA (Vanna trend)", minval=2, maxval=20)
vix_roc_len    = input.int(3,  "VIX ROC (momentum)",    minval=1, maxval=10)
neutral_band   = input.float(0.5, "Neutral band (±pts)", minval=0.1, step=0.1)
show_table     = input.bool(true, "Show Vanna table")
show_bg        = input.bool(true, "Show background tint")

// ─── FETCH VIX ────────────────────────────────────────────────────────────────
// VIX is loaded as a security request — works on any chart symbol
vix = request.security("CBOE:VIX", timeframe.period, close, ignore_invalid_symbol=true)
vix_sma = ta.sma(vix, vix_sma_len)
vix_roc = ta.roc(vix, vix_roc_len)  // 3-day rate of change (%)

// ─── VANNA CLASSIFICATION ─────────────────────────────────────────────────────
// From skill_gex-regime-read.md Question 2:
//   VIX declining → dealers BUY underlying (excess hedge) → long tailwind
//   VIX rising    → dealers SELL underlying (underhedged) → short headwind
//   VIX flat      → neutral, gamma regime is dominant force

vix_above_sma = vix > vix_sma + neutral_band    // rising: short headwind
vix_below_sma = vix < vix_sma - neutral_band    // declining: long tailwind
vix_flat      = not vix_above_sma and not vix_below_sma

vanna_bias = vix_below_sma ? 1 : vix_above_sma ? -1 : 0  // +1 tailwind / -1 headwind / 0 neutral

// Signal magnitude (−2 to +2) matching get_gex_brief() vanna_signal convention
//   +2: VIX declining + ROC < -5%  (accelerating tailwind)
//   +1: VIX declining, moderate
//    0: flat
//   −1: VIX rising, moderate
//   −2: VIX rising + ROC > +5%  (accelerating headwind)
vanna_signal = vix_below_sma and vix_roc < -5 ? 2 :
               vix_below_sma                  ? 1 :
               vix_above_sma and vix_roc > 5  ? -2 :
               vix_above_sma                  ? -1 : 0

// ─── COLORS ──────────────────────────────────────────────────────────────────
TAILWIND_STRONG = color.new(color.green,  40)
TAILWIND        = color.new(color.teal,   50)
NEUTRAL         = color.new(color.gray,   60)
HEADWIND        = color.new(color.orange, 50)
HEADWIND_STRONG = color.new(color.red,    40)

vanna_color = vanna_signal ==  2 ? TAILWIND_STRONG :
              vanna_signal ==  1 ? TAILWIND :
              vanna_signal == -1 ? HEADWIND :
              vanna_signal == -2 ? HEADWIND_STRONG : NEUTRAL

// ─── PLOTS ────────────────────────────────────────────────────────────────────
// VIX line
plot(vix,     "VIX",     color=color.white, linewidth=2)
plot(vix_sma, "VIX SMA", color=color.gray,  linewidth=1)

// Neutral band
upper_band = plot(vix_sma + neutral_band, "SMA + band", color=color.new(color.gray, 80), linewidth=1)
lower_band = plot(vix_sma - neutral_band, "SMA - band", color=color.new(color.gray, 80), linewidth=1)
fill(upper_band, lower_band, color=color.new(color.gray, 92), title="Neutral zone")

// Vanna signal histogram (bottom sub-plot via scaled overlay)
hline(0, "", color=color.new(color.white, 80))
plot(vanna_signal, "Vanna Signal", color=vanna_color, style=plot.style_histogram, linewidth=3)

// Background tint per Vanna regime
bgcolor(show_bg ? color.new(vanna_color, 90) : na, title="Vanna background")

// ─── VANNA TABLE ─────────────────────────────────────────────────────────────
if show_table and barstate.islast
    var table t = table.new(position.top_right, 2, 7, border_width=1)

    bias_text = vanna_signal ==  2 ? "LONG TAILWIND (+2)" :
                vanna_signal ==  1 ? "LONG TAILWIND (+1)" :
                vanna_signal == -1 ? "SHORT HEADWIND (−1)" :
                vanna_signal == -2 ? "SHORT HEADWIND (−2)" : "NEUTRAL (0)"

    table.cell(t, 0, 0, "VANNA BIAS",  text_color=color.gray,   bgcolor=color.new(color.black, 70), text_size=size.small)
    table.cell(t, 1, 0, bias_text,     text_color=vanna_color,   bgcolor=color.new(color.black, 70), text_size=size.normal)

    table.cell(t, 0, 1, "VIX",         text_color=color.gray,   bgcolor=color.new(color.black, 80), text_size=size.small)
    table.cell(t, 1, 1, str.tostring(vix, "#.##"),
               text_color=color.white, bgcolor=color.new(color.black, 80), text_size=size.small)

    table.cell(t, 0, 2, "VIX SMA(" + str.tostring(vix_sma_len) + ")",
               text_color=color.gray,  bgcolor=color.new(color.black, 80), text_size=size.small)
    table.cell(t, 1, 2, str.tostring(vix_sma, "#.##"),
               text_color=color.gray,  bgcolor=color.new(color.black, 80), text_size=size.small)

    vix_direction = vix_below_sma ? "DECLINING ↓" : vix_above_sma ? "RISING ↑" : "FLAT →"
    dir_color     = vix_below_sma ? color.teal : vix_above_sma ? color.orange : color.gray
    table.cell(t, 0, 3, "DIRECTION",   text_color=color.gray,   bgcolor=color.new(color.black, 80), text_size=size.small)
    table.cell(t, 1, 3, vix_direction, text_color=dir_color,    bgcolor=color.new(color.black, 80), text_size=size.small)

    table.cell(t, 0, 4, "ROC (" + str.tostring(vix_roc_len) + "d)",
               text_color=color.gray,  bgcolor=color.new(color.black, 80), text_size=size.small)
    table.cell(t, 1, 4, str.tostring(vix_roc, "#.##") + "%",
               text_color=vix_roc > 0 ? color.orange : color.teal,
               bgcolor=color.new(color.black, 80), text_size=size.small)

    // Implication note
    impl_text  = vanna_signal >=  1 ? "Invisible buyer active" :
                 vanna_signal <= -1 ? "Invisible seller active" : "Gamma regime dominant"
    impl_color = vanna_signal >=  1 ? color.teal : vanna_signal <= -1 ? color.orange : color.gray
    table.cell(t, 0, 5, "IMPLICATION", text_color=color.gray,   bgcolor=color.new(color.black, 80), text_size=size.small)
    table.cell(t, 1, 5, impl_text,     text_color=impl_color,   bgcolor=color.new(color.black, 80), text_size=size.tiny)

    // Trade note
    trade_note = vanna_signal >=  1 ? "Equal lows sweep → long Grade A" :
                 vanna_signal <= -1 ? "Equal highs sweep → short Grade A" : "Structure-driven entries only"
    table.cell(t, 0, 6, "TRADE NOTE",  text_color=color.gray,   bgcolor=color.new(color.black, 80), text_size=size.small)
    table.cell(t, 1, 6, trade_note,    text_color=color.yellow,  bgcolor=color.new(color.black, 80), text_size=size.tiny)

// ─── ALERTS ───────────────────────────────────────────────────────────────────
vanna_turned_bullish = vanna_signal >= 1  and vanna_signal[1] < 1
vanna_turned_bearish = vanna_signal <= -1 and vanna_signal[1] > -1
vanna_went_neutral   = vanna_signal == 0  and vanna_signal[1] != 0

alertcondition(vanna_turned_bullish, "Vanna → Long Tailwind",  "VIX turned below SMA — dealer buying activated")
alertcondition(vanna_turned_bearish, "Vanna → Short Headwind", "VIX turned above SMA — dealer selling activated")
alertcondition(vanna_went_neutral,   "Vanna → Neutral",        "VIX flattened — gamma regime now dominant force")
