{
  "files.exclude": {
    "**/*.mp4": true,
    "**/*.mov": true,
    "**/*.pdf": true,
    "**/.git": true
  },
  "search.exclude": {
    "**/*.mp4": true,
    "**/*.mov": true,
    "**/*.pdf": true,
    "**/.git": true,
    "**/vip data": true,
    "research-deconstruction ": true
  },
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/*.mp4": true,
    "**/*.mov": true,
    "**/*.pdf": true
  },
  "editor.quickSuggestions": {
    "other": false,
    "comments": false,
    "strings": false
  },
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "workbench.editor.enablePreview": true,
  "files.autoSave": "onFocusChange",
  "git.autofetch": false,
  "extensions.autoUpdate": false,
  "telemetry.telemetryLevel": "off"
}
